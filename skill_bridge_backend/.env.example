# SkillBridge Backend Environment Variables
# Copy to .env and fill in your Firebase credentials

# Firebase Admin SDK (for server-side verification)
FIREBASE_ADMIN_PROJECT_ID=skill-bridge-7fff7
FIREBASE_ADMIN_CLIENT_EMAIL=your-service-account@skill-bridge-7fff7.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
